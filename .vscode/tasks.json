{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compile : (compileCurrentFile)",
            "type": "shell",
            "command": "./build.sh",
            "problemMatcher": "$COBOLErrFormat3",
            "group": "build",
            "args": [
                "${file}"
            ]
        },
        {
            "label": "cob",
            "type": "COBOL-shell",
            "command": "cob",
            "problemMatcher": "$COBOLErrFormat3",
            "group": "build",
            "args": [
                {
                    "value": "${file}",
                    "quoting": "escape"
                },
                {
                    "value": "-ug",
                    "quoting": "strong"
                },
                {
                    "value": "-C",
                    "quoting": "strong"
                },
                {
                    "value": "errformat(3)",
                    "quoting": "strong"
                }
            ]
        },
        {
            "type": "COBOL-Ant",
            "mfAntLib": "/opt/microfocus/ED100/lib/mfant.jar",
            "buildTarget": "/home/roch/HUB/PROJETS/VSCODE/FileEnquiry/.cobolBuild",
            "problemMatcher": [
                "$COBOLAntCopybooks",
                "$COBOLAnt"
            ],           
            "group": {                 
               "kind": "build"             
            }
        }
    ]
}